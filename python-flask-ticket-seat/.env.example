FLASK_SECRET_KEY=change-me-in-local-dev
PORT=5001

# Ticket Seat production API. For local Ticket Seat API, use:
# TICKET_SEAT_API_BASE_URL=http://localhost:4000/api/v1
TICKET_SEAT_API_BASE_URL=https://perceptive-heart-production.up.railway.app/api/v1

# Partner token generated in Ticket Seat > Partner > My account.
TICKET_SEAT_PARTNER_TOKEN=tsk_replace_me

# Same secret configured in Ticket Seat partner sandbox webhook settings.
TICKET_SEAT_WEBHOOK_SECRET=ton_secret
